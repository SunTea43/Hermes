<div id="<%= dom_id product %>">
  <div>
    <strong>Business:</strong>
    <%= product.business_id %>
  </div>

  <div>
    <strong>Name:</strong>
    <%= product.name %>
  </div>

  <div>
    <strong>Description:</strong>
    <%= product.description %>
  </div>

  <div>
    <strong>Unit measure:</strong>
    <%= product.unit_measure %>
  </div>

  <div>
    <strong>Status:</strong>
    <%= product.status %>
  </div>

</div>
