<%= simple_form_for(product) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <%= f.association :business,
      collection: policy_scope(Business).order(:name),
      label_method: :name,
      value_method: :id,
      prompt: "Selecciona un negocio",
      label: "Negocio" %>

  <%= f.input :name, label: "Nombre del producto" %>
  <%= f.input :description, as: :text, label: "Descripción", input_html: { rows: 2 }, required: false %>
  <%= f.input :unit_measure, label: "Unidad de medida", hint: "Ej: kg, lt, und, caja" %>
  <%= f.input :status, as: :select,
      collection: [["Activo", "active"], ["Inactivo", "inactive"]],
      label: "Estado",
      prompt: "Selecciona un estado" %>

  <div class="mt-3">
    <%= f.button :submit, class: "btn btn-primary" %>
    <%= link_to "Cancelar", products_path, class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>
