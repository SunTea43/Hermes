<% content_for :title, @product.name %>

<%= render PageHeaderComponent.new(title: @product.name) do %>
  <div class="d-flex gap-2">
    <%= link_to "Editar", edit_product_path(@product), class: "btn btn-outline-secondary btn-sm" %>
    <%= button_to "Eliminar", @product, method: :delete,
        class: "btn btn-outline-danger btn-sm",
        form: { data: { turbo_confirm: "¿Estás seguro?" } } %>
  </div>
<% end %>

<%= render CardComponent.new do %>
  <dl class="row mb-0">
    <dt class="col-sm-3">Negocio</dt>
    <dd class="col-sm-9"><%= @product.business.name %></dd>

    <dt class="col-sm-3">Descripción</dt>
    <dd class="col-sm-9"><%= @product.description.presence || "—" %></dd>

    <dt class="col-sm-3">Unidad de medida</dt>
    <dd class="col-sm-9"><span class="badge bg-secondary"><%= @product.unit_measure %></span></dd>

    <dt class="col-sm-3">Estado</dt>
    <dd class="col-sm-9">
      <% if @product.status == "active" %>
        <span class="badge bg-success">Activo</span>
      <% else %>
        <span class="badge bg-secondary">Inactivo</span>
      <% end %>
    </dd>
  </dl>
<% end %>

<% if @product.inventory %>
  <%= render CardComponent.new(title: "Inventario") do %>
    <dl class="row mb-0">
      <dt class="col-sm-3">Stock actual</dt>
      <dd class="col-sm-9">
        <strong><%= @product.inventory.current_quantity %> <%= @product.unit_measure %></strong>
        <% if @product.inventory.current_quantity < @product.inventory.minimum_alert_quantity %>
          <span class="badge bg-danger ms-2">⚠️ Bajo mínimo</span>
        <% end %>
      </dd>
      <dt class="col-sm-3">Mínimo alerta</dt>
      <dd class="col-sm-9"><%= @product.inventory.minimum_alert_quantity %> <%= @product.unit_measure %></dd>
    </dl>
  <% end %>
<% end %>

<div class="mt-3">
  <%= link_to "← Volver", products_path, class: "text-muted" %>
</div>
