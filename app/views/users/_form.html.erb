<%= form_with(model: user) do |form| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger">
      <h2 class="h6">No se pudo guardar el usuario:</h2>
      <ul class="mb-0">
        <% user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= form.label :name, "Nombre", class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= form.label :email, "Email", class: "form-label" %>
      <%= form.email_field :email, class: "form-control", required: true %>
    </div>

    <div class="col-md-6">
      <%= form.label :whatsapp_phone, "WhatsApp", class: "form-label" %>
      <%= form.telephone_field :whatsapp_phone, class: "form-control", placeholder: "+573000000000" %>
    </div>

    <div class="col-md-6">
      <%= form.label :status, "Estado", class: "form-label" %>
      <%= form.select :status, User::STATUSES.map { |status| [status == "active" ? "Activo" : "Inactivo", status] }, {}, class: "form-select" %>
    </div>

    <div class="col-md-6">
      <%= form.label :password, user.persisted? ? "Nueva contraseña" : "Contraseña", class: "form-label" %>
      <%= form.password_field :password, class: "form-control", required: !user.persisted? %>
      <% if user.persisted? %>
        <div class="form-text">Déjala en blanco para conservar la contraseña actual.</div>
      <% end %>
    </div>

    <div class="col-md-6">
      <%= form.label :password_confirmation, "Confirmar contraseña", class: "form-label" %>
      <%= form.password_field :password_confirmation, class: "form-control", required: !user.persisted? %>
    </div>

    <% unless user.persisted? %>
      <div class="col-md-6">
        <%= form.label :initial_business_id, "Negocio inicial", class: "form-label" %>
        <%= form.collection_select :initial_business_id, @manageable_businesses, :id, :name, { prompt: "Selecciona un negocio" }, class: "form-select", required: true %>
      </div>

      <div class="col-md-6">
        <%= form.label :initial_role, "Rol inicial", class: "form-label" %>
        <%= form.select :initial_role, RoleAssignment::ROLES.map { |role| [role.titleize, role] }, { prompt: "Selecciona un rol" }, class: "form-select", required: true %>
      </div>
    <% end %>
  </div>

  <% if user.persisted? && user != current_user %>
    <hr class="my-4">

    <h2 class="h5">Negocios permitidos</h2>
    <p class="text-muted">Selecciona el rol que esta persona tendrá en cada negocio que administras.</p>

    <div class="row g-3">
      <% @manageable_businesses.each do |business| %>
        <% assignment = user.role_assignments.find { |item| item.business_id == business.id && item.status == "active" } %>
        <% assigned_modules = assignment&.assigned_modules.to_s.split(",") %>
        <div class="col-md-6">
          <div class="border rounded p-3 h-100">
            <%= label_tag "user_permitted_roles_#{business.id}", business.name, class: "form-label fw-semibold" %>
            <%= select_tag "user[permitted_roles][#{business.id}]",
              options_for_select([ [ "Sin acceso", "" ] ] + RoleAssignment::ROLES.map { |role| [ role.titleize, role ] }, user.role_for(business)),
              id: "user_permitted_roles_#{business.id}",
              class: "form-select" %>

            <%= hidden_field_tag "user[permitted_modules][#{business.id}][]", "" %>
            <div class="mt-2 d-flex gap-3">
              <% { "sales" => "Ventas", "purchases" => "Compras" }.each do |module_name, label| %>
                <div class="form-check">
                  <%= check_box_tag "user[permitted_modules][#{business.id}][]",
                    module_name,
                    assigned_modules.include?(module_name),
                    id: "user_permitted_modules_#{business.id}_#{module_name}",
                    class: "form-check-input" %>
                  <%= label_tag "user_permitted_modules_#{business.id}_#{module_name}",
                    label,
                    class: "form-check-label" %>
                </div>
              <% end %>
            </div>
            <div class="form-text">Los módulos limitan las escrituras del rol Operator.</div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if user.persisted? %>
    <hr class="my-4">

    <h2 class="h5">Preferencia de WhatsApp</h2>
    <p class="text-muted">
      El acceso por WhatsApp se habilita en cada rol de negocio (Roles → Editar).
      Aquí solo se elige la tienda predeterminada cuando hay varias autorizadas.
    </p>

    <div class="mt-3">
      <%= form.label :default_whatsapp_business_id, "Tienda predeterminada de WhatsApp", class: "form-label" %>
      <%= form.collection_select :default_whatsapp_business_id,
        @manageable_businesses,
        :id,
        :name,
        { include_blank: "Sin tienda predeterminada" },
        class: "form-select" %>
      <div class="form-text">Debe ser una tienda accesible y autorizada para WhatsApp.</div>
    </div>
  <% end %>

  <div class="mt-4 d-flex gap-2">
    <%= form.submit user.persisted? ? "Guardar cambios" : "Crear usuario", class: "btn btn-primary" %>
    <%= link_to "Cancelar", user.persisted? ? user_path(user) : users_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
