<% content_for :title, "Negocios" %>

<%= render PageHeaderComponent.new(title: "Negocios") do %>
  <%= link_to "+ Nuevo negocio", new_business_path, class: "btn btn-primary" %>
<% end %>

<div class="row g-3">
  <% @businesses.each do |business| %>
    <div class="col-md-6 col-lg-4">
      <%= render CardComponent.new(title: business.name) do %>
        <p class="text-muted mb-1"><%= business.description.presence || "Sin descripción" %></p>
        <p class="mb-2"><span class="badge bg-secondary"><%= business.currency %></span></p>
        <div class="d-flex gap-2">
          <%= link_to "Ver", business, class: "btn btn-sm btn-outline-primary" %>
          <%= link_to "Editar", edit_business_path(business), class: "btn btn-sm btn-outline-secondary" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
