<%= render PageHeaderComponent.new(title: "Orden de venta: #{@sales_order.reference_number}") do %>
  <div class="d-flex gap-2">
    <%= link_to "Editar", edit_sales_order_path(@sales_order), class: "btn btn-outline-secondary btn-sm" %>
    <%= button_to "Eliminar", @sales_order, method: :delete,
        class: "btn btn-outline-danger btn-sm",
        form: { data: { turbo_confirm: "¿Estás seguro?" } } %>
  </div>
<% end %>

<%= render CardComponent.new do %>
  <dl class="row mb-0">
    <dt class="col-sm-3">Negocio</dt>
    <dd class="col-sm-9"><%= @sales_order.business&.name || "—" %></dd>

    <dt class="col-sm-3">Cliente</dt>
    <dd class="col-sm-9"><%= @sales_order.customer_name %></dd>

    <dt class="col-sm-3">Identificación</dt>
    <dd class="col-sm-9"><%= @sales_order.customer_identifier.presence || "—" %></dd>

    <dt class="col-sm-3">Condición de pago</dt>
    <dd class="col-sm-9"><%= @sales_order.payment_condition %></dd>

    <dt class="col-sm-3">Estado de pago</dt>
    <dd class="col-sm-9"><span class="badge bg-secondary"><%= @sales_order.payment_status %></span></dd>

    <dt class="col-sm-3">Vencimiento</dt>
    <dd class="col-sm-9"><%= @sales_order.payment_due_at&.strftime("%d/%m/%Y") || "—" %></dd>

    <dt class="col-sm-3">Total</dt>
    <dd class="col-sm-9"><strong><%= number_to_currency(@sales_order.total, unit: @sales_order.business&.currency || "$", separator: ",", delimiter: ".") %></strong></dd>

    <dt class="col-sm-3">Creado por</dt>
    <dd class="col-sm-9"><%= @sales_order.created_by&.name.presence || @sales_order.created_by&.email || "—" %></dd>

    <dt class="col-sm-3">Notas</dt>
    <dd class="col-sm-9"><%= @sales_order.notes.presence || "—" %></dd>
  </dl>
<% end %>

<div class="mt-3">
  <%= link_to "← Volver", sales_orders_path, class: "text-muted" %>
</div>
