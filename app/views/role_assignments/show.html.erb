<% content_for :title, "Detalle de rol" %>

<%= render PageHeaderComponent.new(title: "Detalle de rol", subtitle: @role_assignment.user.display_name) do %>
  <%= link_to "Editar", edit_role_assignment_path(@role_assignment), class: "btn btn-outline-secondary btn-sm" %>
<% end %>

<%= render CardComponent.new do %>
  <%= render @role_assignment %>
<% end %>

<div class="mt-3 d-flex gap-2">
  <%= link_to "Volver al usuario", @role_assignment.user, class: "btn btn-outline-primary" %>
  <%= link_to "Ver roles", role_assignments_path, class: "btn btn-outline-secondary" %>
</div>
