<% content_for :title, "Inventario" %>

<%= render PageHeaderComponent.new(title: "Inventario") %>

<%# ── Tarjetas de resumen ────────────────────────────────── %>
<div class="row g-3 mb-4">
  <div class="col-sm-4">
    <%= render CardComponent.new do %>
      <div class="d-flex align-items-center gap-3">
        <div class="fs-2">📦</div>
        <div>
          <div class="fs-4 fw-bold"><%= @total_products %></div>
          <div class="text-muted small">Productos en inventario</div>
        </div>
      </div>
    <% end %>
  </div>
  <div class="col-sm-4">
    <%= render CardComponent.new do %>
      <div class="d-flex align-items-center gap-3">
        <div class="fs-2">⚠️</div>
        <div>
          <div class="fs-4 fw-bold text-warning"><%= @below_minimum.count %></div>
          <div class="text-muted small">Bajo stock mínimo</div>
        </div>
      </div>
    <% end %>
  </div>
  <div class="col-sm-4">
    <%= render CardComponent.new do %>
      <div class="d-flex align-items-center gap-3">
        <div class="fs-2">🔴</div>
        <div>
          <div class="fs-4 fw-bold text-danger"><%= @out_of_stock.count %></div>
          <div class="text-muted small">Sin stock</div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# ── Alertas de stock crítico ───────────────────────────── %>
<% if @out_of_stock.any? || @below_minimum.any? %>
  <div class="alert alert-warning d-flex flex-wrap gap-2 align-items-start mb-4">
    <strong class="me-2">⚠️ Atención:</strong>
    <% @out_of_stock.each do |i| %>
      <span class="badge bg-danger">
        <%= i.product.name %> — Sin stock
      </span>
    <% end %>
    <% (@below_minimum - @out_of_stock).each do |i| %>
      <span class="badge bg-warning text-dark">
        <%= i.product.name %> — <%= i.current_quantity %> <%= i.product.unit_measure %> (mín. <%= i.minimum_alert_quantity %>)
      </span>
    <% end %>
  </div>
<% end %>

<%# ── Tabla principal ────────────────────────────────────── %>
<% if @inventories.any? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>Producto</th>
          <th>Negocio</th>
          <th class="text-end">Stock actual</th>
          <th class="text-end">Stock mínimo</th>
          <th class="text-center">Estado</th>
          <th class="text-muted small">Actualizado</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @inventories.each do |inventory| %>
          <%
            ratio   = inventory.minimum_alert_quantity > 0 ? inventory.current_quantity / inventory.minimum_alert_quantity : 1
            status  = if inventory.current_quantity <= 0
              { label: "Sin stock", css: "danger", icon: "🔴" }
            elsif ratio < 1
              { label: "Bajo mínimo", css: "warning", icon: "⚠️" }
            else
              { label: "Normal", css: "success", icon: "✅" }
            end
          %>
          <tr class="<%= 'table-danger' if inventory.current_quantity <= 0 %><%= ' table-warning' if ratio < 1 && inventory.current_quantity > 0 %>">
            <td>
              <strong><%= inventory.product.name %></strong>
              <% if inventory.product.description.present? %>
                <br><small class="text-muted"><%= inventory.product.description.truncate(50) %></small>
              <% end %>
            </td>
            <td><span class="badge bg-secondary"><%= inventory.business.name %></span></td>
            <td class="text-end fw-bold">
              <%= number_with_precision(inventory.current_quantity, precision: 2, strip_insignificant_zeros: true) %>
              <small class="text-muted"><%= inventory.product.unit_measure %></small>
            </td>
            <td class="text-end text-muted">
              <%= number_with_precision(inventory.minimum_alert_quantity, precision: 2, strip_insignificant_zeros: true) %>
              <small><%= inventory.product.unit_measure %></small>
            </td>
            <td class="text-center">
              <span class="badge bg-<%= status[:css] %>">
                <%= status[:icon] %> <%= status[:label] %>
              </span>
            </td>
            <td class="text-muted small">
              <%= inventory.last_updated_at ? time_ago_in_words(inventory.last_updated_at) + " ago" : "—" %>
            </td>
            <td class="text-end">
              <%= link_to "Ver", inventory, class: "btn btn-sm btn-outline-primary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="text-center text-muted py-5">
    <p class="fs-5">No hay inventario registrado.</p>
    <p class="small">El inventario se crea automáticamente al importar productos o registrar compras.</p>
  </div>
<% end %>
