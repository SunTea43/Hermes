<% content_for :title, "Editar inventario" %>

<%= render PageHeaderComponent.new(title: "Editar stock mínimo: #{@inventory.product.name}") do %>
  <%= link_to "← Ver inventario", @inventory, class: "btn btn-outline-secondary btn-sm" %>
<% end %>

<%= render CardComponent.new do %>
