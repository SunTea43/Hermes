<%= simple_form_for(inventory) do |f| %>
  <%= f.error_notification %>

  <% unless inventory.persisted? %>
    <%= f.association :business,
        collection: policy_scope(Business).order(:name),
        label_method: :name,
        value_method: :id,
        prompt: "Selecciona un negocio",
        label: "Negocio" %>

    <%= f.association :product,
        collection: policy_scope(Product).order(:name),
        label_method: ->(p) { "#{p.name} (#{p.unit_measure})" },
        value_method: :id,
        prompt: "Selecciona un producto",
        label: "Producto" %>

    <%= f.input :current_quantity,
        label: "Cantidad actual",
        input_html: { step: "0.01", min: "0" } %>
  <% end %>

  <%= f.input :minimum_alert_quantity,
      label: "Cantidad mínima para alerta",
      hint: "Se mostrará una alerta cuando el stock baje de este valor",
      input_html: { step: "0.01", min: "0" } %>

  <div class="mt-3">
    <%= f.button :submit, class: "btn btn-primary" %>
    <%= link_to "Cancelar", inventories_path, class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>
