<%= render PageHeaderComponent.new(title: "Orden de compra: #{@purchase_order.reference_number}") do %>
  <div class="d-flex gap-2">
    <%= link_to "Editar", edit_purchase_order_path(@purchase_order), class: "btn btn-outline-secondary btn-sm" %>
    <%= button_to "Eliminar", @purchase_order, method: :delete,
        class: "btn btn-outline-danger btn-sm",
        form: { data: { turbo_confirm: "¿Estás seguro?" } } %>
  </div>
<% end %>

<%= render CardComponent.new do %>
  <dl class="row mb-0">
    <dt class="col-sm-3">Negocio</dt>
    <dd class="col-sm-9"><%= @purchase_order.business&.name || "—" %></dd>

    <dt class="col-sm-3">Proveedor</dt>
    <dd class="col-sm-9"><%= @purchase_order.supplier_name || "—" %></dd>

    <dt class="col-sm-3">Estado</dt>
    <dd class="col-sm-9"><span class="badge bg-secondary"><%= @purchase_order.status %></span></dd>

    <dt class="col-sm-3">Recepción</dt>
    <dd class="col-sm-9"><%= @purchase_order.received_at&.strftime("%d/%m/%Y %H:%M") || "—" %></dd>

    <dt class="col-sm-3">Creado por</dt>
    <dd class="col-sm-9"><%= @purchase_order.created_by&.name.presence || @purchase_order.created_by&.email || "—" %></dd>

    <dt class="col-sm-3">Notas</dt>
    <dd class="col-sm-9"><%= @purchase_order.notes.presence || "—" %></dd>
  </dl>
<% end %>

<div class="mt-3">
  <%= link_to "← Volver", purchase_orders_path, class: "text-muted" %>
</div>
