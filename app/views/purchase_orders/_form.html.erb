<%= simple_form_for(purchase_order) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <%= f.association :business,
      collection: policy_scope(Business).order(:name),
      label_method: :name,
      value_method: :id,
      prompt: "Selecciona un negocio",
      label: "Negocio" %>

  <%= f.input :reference_number, label: "Número de referencia", hint: "Ej: OC-2024-001" %>

  <%= f.association :created_by,
      collection: User.order(:name, :email),
      label_method: ->(u) { u.name.presence || u.email },
      value_method: :id,
      prompt: "Selecciona un responsable",
      label: "Creado por",
      required: false %>

  <%= f.input :supplier_name, label: "Nombre del proveedor" %>

  <%= f.input :status, as: :select,
      collection: PurchaseOrder::STATUSES,
      label: "Estado",
      prompt: "Selecciona un estado" %>

  <%= f.input :received_at, as: :datetime,
      label: "Fecha de recepción",
      required: false %>

  <%= f.input :notes, as: :text,
      label: "Notas",
      input_html: { rows: 3 },
      required: false %>

  <hr class="my-4">
  <h6 class="mb-3 fw-semibold">Productos de la orden</h6>

  <div data-controller="nested-form">
    <div data-nested-form-target="container">
      <%= f.fields_for :purchase_order_items do |item_f| %>
        <%= render "purchase_order_item_fields", f: item_f %>
      <% end %>
    </div>

    <template data-nested-form-target="template">
      <%= f.fields_for :purchase_order_items, PurchaseOrderItem.new, child_index: "NEW_RECORD" do |item_f| %>
        <%= render "purchase_order_item_fields", f: item_f %>
      <% end %>
    </template>

    <button type="button"
            class="btn btn-outline-secondary btn-sm mb-3"
            data-action="nested-form#addItem">
      + Agregar producto
    </button>
  </div>

  <div class="mt-3">
    <%= f.button :submit, class: "btn btn-primary" %>
    <%= link_to "Cancelar", purchase_orders_path, class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>
